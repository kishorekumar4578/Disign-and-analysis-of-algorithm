#include <stdio.h>
#include <stdlib.h>

// Node structure
struct Node {
    char data;
    float freq;
    struct Node *left, *right;
};

// Create new node
struct Node* createNode(char data, float freq) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = data;
    newNode->freq = freq;
    newNode->left = newNode->right = NULL;
    return newNode;
}

// Swap nodes
void swap(struct Node** a, struct Node** b) {
    struct Node* temp = *a;
    *a = *b;
    *b = temp;
}

// Sort nodes by frequency (Bubble sort)
void sort(struct Node* arr[], int n) {
    for(int i = 0; i < n-1; i++) {
        for(int j = 0; j < n-i-1; j++) {
            if(arr[j]->freq > arr[j+1]->freq) {
                swap(&arr[j], &arr[j+1]);
            }
        }
    }
}

// Print current nodes
void printNodes(struct Node* nodes[], int size) {
    printf("\nCurrent nodes:\n");
    for(int i = 0; i < size; i++) {
        if(nodes[i]->data == '$')
            printf("(%.2f) ", nodes[i]->freq);
        else
            printf("(%c:%.2f) ", nodes[i]->data, nodes[i]->freq);
    }
    printf("\n");
}

// Build Huffman Tree
struct Node* buildHuffmanTree(struct Node* nodes[], int size) {
    while(size > 1) {
        sort(nodes, size);

        // Pick two smallest nodes
        struct Node* left = nodes[0];
        struct Node* right = nodes[1];

        // Create new internal node
        struct Node* newNode = createNode('$', left->freq + right->freq);
        newNode->left = left;
        newNode->right = right;

        // Replace first two nodes with new node
        nodes[0] = newNode;
        nodes[1] = nodes[size - 1];

        size--;

        printNodes(nodes, size);
    }

    return nodes[0];
}

// Print Huffman Codes
void printCodes(struct Node* root, int arr[], int top) {
    if(root->left) {
        arr[top] = 0;
        printCodes(root->left, arr, top + 1);
    }

    if(root->right) {
        arr[top] = 1;
        printCodes(root->right, arr, top + 1);
    }

    // Leaf node
    if(root->left == NULL && root->right == NULL) {
        printf("%c: ", root->data);
        for(int i = 0; i < top; i++)
            printf("%d", arr[i]);
        printf("\n");
    }
}

int main() {
    int n;

    printf("Enter number of characters: ");
    scanf("%d", &n);

    struct Node* nodes[n];


    for(int i = 0; i < n; i++) {
        char ch;
        float freq;

        printf("Enter character and frequency: ");
        scanf(" %c %f", &ch, &freq);

        nodes[i] = createNode(ch, freq);
    }

    printNodes(nodes, n);
    struct Node* root = buildHuffmanTree(nodes, n);
    int arr[100], top = 0;
    printf("\nHuffman Codes:\n");
    printCodes(root, arr, top);

    return 0;
}
