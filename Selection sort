#include<stdio.h>
int main() {
   int i,n,j,min,temp;
   printf("Enter the number of elements:");
   scanf("%d",&n);
   int A[n];
   printf("Enter the elements of array:");
   for (i =0;i<n;i++){
      scanf("%d",&A[i]);
   }
   for (i=0;i<=n-1;i++){
      for(j=i+1;j<=(n-2)-i;j++) {
         if(A[j]<A[i])
         {
            temp = A[j];
            A[j]=A[i];
            A[i]=temp;
         }
      }
   }
   printf("SORTED ARRAY:");
   for (i=0;i<n;i++){
      printf("\t%d\t",A[i]);
   }
   return 0;
}
